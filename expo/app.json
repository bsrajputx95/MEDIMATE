{
  "expo": {
    "name": "Medimate",
    "slug": "medimate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "medimate",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366F1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.medimate.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Medimate to access your camera to scan food items",
        "NSMicrophoneUsageDescription": "Allow Medimate to access your microphone",
        "NSPhotoLibraryUsageDescription": "Allow Medimate to access your photos to analyze food"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#6366F1"
      },
      "package": "com.medimate.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://medimatev1.com/"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Medimate to access your camera to scan food items",
          "microphonePermission": "Allow Medimate to access your microphone",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Medimate accesses your photos to analyze food for nutritional content."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
